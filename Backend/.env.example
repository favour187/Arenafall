# ─── Arena Fall Backend Configuration ───

# Server
PORT=3000
NODE_ENV=production
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/arenafall?retryWrites=true&w=majority

# Redis (for matchmaking queue & session cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Game Settings
MAX_PLAYERS_PER_MATCH=60
MATCH_QUEUE_TIMEOUT=120
TICK_RATE=20

# Anti-Cheat
ANTICHEAT_ENABLED=true
MAX_PING_MS=500
MAX_PACKET_LOSS=0.3
SPEED_HACK_THRESHOLD=1.5

# Encryption
ENCRYPTION_KEY=your-32-char-aes-key-here-change-me
ENCRYPTION_IV=your-16-char-iv-here-change

# Logging
LOG_LEVEL=info
LOG_FILE=logs/arenafall.log

# Analytics
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=30000
